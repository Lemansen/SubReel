<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AccentBlue" Color="#3374FF" x:Shared="False"/>
    <SolidColorBrush x:Key="BgDark" Color="#08080A"/>
    <SolidColorBrush x:Key="CardBg" Color="#111217"/>
    <SolidColorBrush x:Key="TextGray" Color="#8E8E93"/>
    <SolidColorBrush x:Key="BorderSharp" Color="#30313C"/>
    <SolidColorBrush x:Key="PanelBg" Color="#0F111A"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#252836"/>
    <SolidColorBrush x:Key="PanelSoftBorder" Color="#1C1F2B"/>
    <SolidColorBrush x:Key="PanelHover" Color="#161A26"/>
    <SolidColorBrush x:Key="GlowBlue" Color="#3374FF"/>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                        <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border Background="#3A3A45" CornerRadius="3" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="CrashCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="BorderBrush" Value="#FF4444"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                Color="#FF4444"
                BlurRadius="25"
                ShadowDepth="0"
                Opacity="0.45"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!-- появление как в установщике -->
            <Trigger Property="Visibility" Value="Visible">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>

                            <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            To="1"
                            Duration="0:0:0.35"/>

                            <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                            To="1"
                            Duration="0:0:0.35"/>

                            <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                            To="1"
                            Duration="0:0:0.35"/>

                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>

        </Style.Triggers>
    </Style>
    <Style x:Key="ModernSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="#14151B"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid x:Name="GridRoot">
                        <Border x:Name="TrackBackground" Background="{TemplateBinding Background}" Height="6" CornerRadius="3" VerticalAlignment="Center" Margin="5,0"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="{StaticResource AccentBlue}" Height="6" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="6"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="18" Height="18">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid>
                                                <Ellipse Fill="{StaticResource AccentBlue}" Opacity="0.3">
                                                    <Ellipse.Effect>
                                                        <BlurEffect Radius="10"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Ellipse Fill="White" Stroke="{StaticResource AccentBlue}" StrokeThickness="3"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#111217"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border x:Name="TipBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Opacity="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="0" Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter Margin="{TemplateBinding Padding}">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TipBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    <ThicknessAnimation Storyboard.TargetName="TipBorder" Storyboard.TargetProperty="Margin" From="0,5,0,-5" To="0" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Grid Width="18" Height="18">
                            <Border x:Name="box" Background="#08080A" CornerRadius="5" BorderThickness="1.5" BorderBrush="#25262F"/>
                            <Path x:Name="mark" Data="M4,9 L8,13 L14,5" Stroke="{StaticResource AccentBlue}" StrokeThickness="2" Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="mark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#12131A"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5"/>
        <Style.Resources>
            <Style TargetType="MenuItem">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="5" Margin="2">
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBlue}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <Style x:Key="ControlButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#444"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="45"/>
        <Setter Property="Margin" Value="12,4"/>
        <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="15,0">
                        <Grid>
                            <Rectangle x:Name="ActiveIndicator" Width="3" Height="0" Fill="{StaticResource AccentBlue}" RadiusX="1.5" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-5,0,0,0"/>
                            <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="#1D1E26"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="Active">
                            <Setter TargetName="ActiveIndicator" Property="Height" Value="18"/>
                            <Setter TargetName="btnBorder" Property="Background" Value="#15161E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="KillButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1AFF4444"/>
        <Setter Property="Foreground" Value="#FF6666"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="15,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="IsEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Glow" Background="#FF4444" Opacity="0" CornerRadius="10">
                            <Border.Effect>
                                <BlurEffect Radius="12"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="#33FF4444" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#FF4444"/>
                            <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FF4444"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="Glow" Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="PlayButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="#20F289"/>
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Style.Triggers>

        <!-- загрузка -->
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="downloading">
            <Setter Property="Background" Value="#F2C94C"/>
        </DataTrigger>

        <!-- запуск -->
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="launching">
            <Setter Property="Background" Value="#56CCF2"/>
        </DataTrigger>

        <!-- ошибка -->
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="error">
            <Setter Property="Background" Value="#EB5757"/>
            <Setter Property="Foreground" Value="White"/>
        </DataTrigger>

    </Style.Triggers>
</Style>
    <Style x:Key="AnimatedAccentPlayButtonStyle" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>

                        <!-- мягкое свечение -->
                        <Border x:Name="Glow"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Opacity="0.35">
                            <Border.Effect>
                                <BlurEffect Radius="22"/>
                            </Border.Effect>
                        </Border>

                        <!-- основная форма -->
                        <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            BorderBrush="#4C85FF"
                            BorderThickness="1">

                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        </Border>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Glow" Property="Opacity" Value="0.5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- Click -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Glow" Property="Opacity" Value="0.2"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- состояния через Tag -->
        <Style.Triggers>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="downloading">
                <Setter Property="Background" Value="#F2C94C"/>
                <Setter Property="Foreground" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="launching">
                <Setter Property="Background" Value="#56CCF2"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="error">
                <Setter Property="Background" Value="#EB5757"/>
            </DataTrigger>

        </Style.Triggers>

    </Style>
    <Style x:Key="AccentPlayButtonStyle" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>

                        <!-- мягкое синее свечение -->
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Opacity="0.35">
                            <Border.Effect>
                                <BlurEffect Radius="20"/>
                            </Border.Effect>
                        </Border>

                        <!-- основная форма -->
                        <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            BorderBrush="#4C85FF"
                            BorderThickness="1">

                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        </Border>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder"
                                Property="Opacity"
                                Value="0.9"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder"
                                Property="Opacity"
                                Value="0.75"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- состояния -->
        <Style.Triggers>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="downloading">
                <Setter Property="Background" Value="#F2C94C"/>
                <Setter Property="Foreground" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="launching">
                <Setter Property="Background" Value="#56CCF2"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="error">
                <Setter Property="Background" Value="#EB5757"/>
            </DataTrigger>

        </Style.Triggers>

    </Style>
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1AFFFFFF"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                        CornerRadius="8" BorderThickness="1" BorderBrush="#22FFFFFF">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#2AFFFFFF"/>
                            <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#151825"/>
        <Setter Property="BorderBrush" Value="#2A2D3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <!-- ВАЖНО: не задаём MinWidth / MinHeight -->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter
                        RecognizesAccessKey="True"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            <Setter TargetName="border" Property="Background" Value="#1B1E29"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#141621"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#252836"/>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12"
                              ShadowDepth="0"
                              Opacity="0.25"
                              Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>